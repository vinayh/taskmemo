# Copy to `.env` and fill in your values. Run with:
#   uv run --env-file .env print_day.py [--dry-run|--debug]

# Required: fully-qualified MCP tool name in the form mcp__<server>__<tool>.
# The server it belongs to must be reachable to `claude -p` (project
# `.mcp.json`, user-level config, or via TASKMEMO_MCP_CONFIG below).
TASKMEMO_MCP_TOOL=

# Strongly recommended: path or inline JSON for an isolated MCP config.
# When set, the script passes --strict-mcp-config --mcp-config $TASKMEMO_MCP_CONFIG
# to claude, so only that one server spawns instead of every globally-
# registered MCP server.
TASKMEMO_MCP_CONFIG=

# Required: path to the system prompt file (relative to repo root, or
# absolute). Start from prompt.example.md.
TASKMEMO_PROMPT_FILE=prompt.md

# Optional: Claude model alias for the curation step. Defaults to "opus".
# CURATE_MODEL=opus

# Optional: BLE local name to scan for. Defaults to "M02 Pro".
# PHOMEMO_DEVICE_NAME=M02 Pro

# Optional: BLE write tuning. Defaults paced for the M02 Pro's small
# per-write buffer; only override if you know what you're doing.
# PHOMEMO_CHUNK_SIZE=
# PHOMEMO_CHUNK_DELAY_MS=40
