# Griply (Firebase auth used by griply-mcp)
GRIPLY_EMAIL=
GRIPLY_PASSWORD=
GRIPLY_TIMEZONE=America/New_York

# Path to the griply-mcp checkout that this script will spawn over stdio.
GRIPLY_MCP_PATH=/Users/vinay/Dev/griply-mcp

# Optional: if scanning by name fails, set this to the exact local name
# advertised by your printer (commonly "M02 Pro").
PHOMEMO_DEVICE_NAME=M02 Pro
